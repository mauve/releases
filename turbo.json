{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "sync-schema": {
      "cache": false,
      "outputs": ["src/schema/**", "src/generated/**"]
    },
    "sync-actions": {
      "cache": false,
      "outputs": ["src/generated/**"]
    }
  }
}
