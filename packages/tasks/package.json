{
  "name": "@mauvezero/azpipe-tasks",
  "version": "0.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauve/releases.git"
  },
  "description": "Typed function helpers for every (non-deprecated) task in microsoft/azure-pipelines-tasks.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "sync-tasks": "tsx scripts/sync-tasks.ts"
  },
  "dependencies": {
    "@mauvezero/azpipe": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
