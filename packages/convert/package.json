{
  "name": "@mauvezero/azpipe-convert",
  "version": "0.5.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauve/releases.git"
  },
  "description": "Convert existing azure-pipelines.yml and classic release JSON into TypeScript that uses @mauvezero/azpipe builders.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mauvezero/azpipe": "workspace:*",
    "@mauvezero/azpipe-core": "workspace:*",
    "@mauvezero/azpipe-releases": "workspace:*",
    "@mauvezero/azpipe-tasks": "workspace:*",
    "@mauvezero/azpipe-utils": "workspace:*",
    "@mauvezero/ghactions": "workspace:*",
    "@mauvezero/ghactions-actions": "workspace:*",
    "prettier": "^3.4.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
