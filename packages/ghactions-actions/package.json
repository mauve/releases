{
  "name": "@mauvezero/ghactions-actions",
  "version": "0.6.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauve/releases.git"
  },
  "description": "Auto-generated type-safe wrappers for known GitHub Actions (actions/ org + popular third-party).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "sync-actions": "tsx scripts/sync-actions.ts"
  },
  "dependencies": {
    "@mauvezero/ghactions": "workspace:*"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
