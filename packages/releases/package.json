{
  "name": "@mauve/azpipe-releases",
  "version": "0.1.0",
  "description": "Typesafe builders for Azure DevOps Classic Release definitions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mauve/azpipe": "workspace:*",
    "@mauve/azpipe-tasks": "workspace:*",
    "@mauve/azpipe-utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
