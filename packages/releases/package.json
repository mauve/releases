{
  "name": "@mauvezero/azpipe-releases",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauve/releases.git"
  },
  "description": "Typesafe builders for Azure DevOps Classic Release definitions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mauvezero/azpipe": "workspace:*",
    "@mauvezero/azpipe-tasks": "workspace:*",
    "@mauvezero/azpipe-utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
