{
  "name": "@mauve/azpipe-cli",
  "version": "0.1.0",
  "description": "CLI for compiling TS-authored Azure Pipelines into YAML/JSON.",
  "type": "module",
  "main": "./dist/bin.js",
  "bin": {
    "azpipe": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mauve/azpipe": "workspace:*",
    "@mauve/azpipe-convert": "workspace:*",
    "@mauve/azpipe-core": "workspace:*",
    "@mauve/azpipe-tasks": "workspace:*",
    "@mauve/azpipe-utils": "workspace:*",
    "@mauve/azpipe-releases": "workspace:*",
    "@mauve/azpipe-releases-client": "workspace:*",
    "tsx": "^4.19.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
